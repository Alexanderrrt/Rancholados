# Square Web Payments SDK and Payments API
SQUARE_ENVIRONMENT=sandbox
SQUARE_APPLICATION_ID=
SQUARE_LOCATION_ID=
SQUARE_ACCESS_TOKEN=

# Uber Direct API
UBER_DIRECT_CLIENT_ID=
UBER_DIRECT_CLIENT_SECRET=
UBER_DIRECT_CUSTOMER_ID=
UBER_WEBHOOK_SIGNING_KEY=

# Store pickup details sent to Uber Direct
UBER_PICKUP_STREET_1=1075 Tully Rd
UBER_PICKUP_STREET_2=Suite 24
UBER_PICKUP_CITY=San Jose
UBER_PICKUP_STATE=CA
UBER_PICKUP_POSTAL_CODE=95122
UBER_PICKUP_PHONE=+14087975538
UBER_PICKUP_NOTES=Pickup at Rancholados counter.

# Generate at least 32 random characters. Never expose this to the browser.
CHECKOUT_SIGNING_SECRET=

# Optional local-development checkout. It never charges or dispatches and is disabled in production.
CHECKOUT_DEMO_MODE=false
CHECKOUT_DEMO_DELIVERY_FEE_CENTS=699

# Tax in basis points. Example: 937 = 9.37%. Confirm the correct rate before launch.
CHECKOUT_TAX_RATE_BPS=0
